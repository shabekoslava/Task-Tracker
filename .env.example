# =============================================================
# 🔐 Переменные окружения проекта Task Tracker
# =============================================================
# Скопируйте этот файл в .env и заполните значения:
#   copy .env.example .env

# --- База данных PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_YOUR_DB_PASSWORD
POSTGRES_DB=task_tracker_bd
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_YOUR_DB_PASSWORD@postgres:5432/task_tracker_bd

# --- JWT (JSON Web Tokens) ---
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Pepper для дополнительного хеширования паролей ---
PASSWORD_PEPPER=CHANGE_ME_RANDOM_PEPPER
